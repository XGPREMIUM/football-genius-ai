# Proveedor de IA: "openai" | "anthropic" | "local"
AI_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-tu-api-key-aqui
OPENAI_MODEL=gpt-4o

# Anthropic
ANTHROPIC_API_KEY=sk-ant-tu-api-key-aqui
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Modo por defecto: scout | tactical | transfer_market | journalist | goat | encyclopedia | content_creator | coach | talent_detector | sporting_director | statistician | general
DEFAULT_MODE=general

# Temperatura del modelo (0.0 - 1.0)
AI_TEMPERATURE=0.7

# Máximo de tokens en la respuesta
AI_MAX_TOKENS=4096

# Puerto para el servidor API
API_PORT=8000
